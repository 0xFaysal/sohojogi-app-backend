NODE_ENV=development
PORT=3000
APP_NAME=Sohojogi
API_VERSION=v1

MONGO_URI=mongodb://127.0.0.1:27017/shojogi

SUPER_ADMIN_EMAIL=admin@example.com
SUPER_ADMIN_PASSWORD=change-me

JWT_ACCESS_SECRET=replace-with-secure-access-secret
JWT_REFRESH_SECRET=replace-with-secure-refresh-secret
JWT_ACCESS_EXPIRY=1h
JWT_REFRESH_EXPIRY=7d

BCRYPT_SALT_ROUNDS=12

LOG_LEVEL=debug
LOG_FILE_PATH=./logs

EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_ENABLED=true
EMAIL_USER=your-email@example.com
EMAIL_PASS=your-email-app-password
EMAIL_FROM="SHOJOGI" <your-email@example.com>

OTP_MAX_ATTEMPTS=5
OTP_EXPIRY_MINUTES=10
STRICT_MAX_ATTEMPTS=10

CLOUDINARY_CLOUD_NAME=your-cloudinary-cloud
CLOUDINARY_API_KEY=your-cloudinary-key
CLOUDINARY_API_SECRET=your-cloudinary-secret
